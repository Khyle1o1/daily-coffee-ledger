VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-key>
# Local fallback version when Vercel metadata is unavailable
VITE_APP_VERSION=local
# In Vercel, map these to built-ins:
# VITE_VERCEL_GIT_COMMIT_SHA=$VERCEL_GIT_COMMIT_SHA
# VITE_VERCEL_GIT_COMMIT_REF=$VERCEL_GIT_COMMIT_REF
VITE_VERCEL_GIT_COMMIT_SHA=
VITE_VERCEL_GIT_COMMIT_REF=

# Server-only secret. Never expose this in VITE_* variables.
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# For backend/serverless runtimes that use direct Postgres access:
# Use Supabase pooled connection (port 6543), not direct 5432.
DATABASE_URL=postgresql://<user>:<password>@<project-ref>.pooler.supabase.com:6543/postgres
